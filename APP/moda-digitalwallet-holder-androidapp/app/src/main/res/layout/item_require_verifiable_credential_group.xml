<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/view_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="20dp"
            android:background="@drawable/shape_r12_item_background_selected_2"
            tools:layout_editor_absoluteX="0dp"
            tools:layout_editor_absoluteY="1dp">

            <TextView
                android:id="@+id/tv_card_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="28dp"
                android:textColor="@color/primary_08"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv_change_verification_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="第一證件身分證明" />

            <TextView
                android:id="@+id/tv_change_verification_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_credential_2"
                android:textColor="@color/primary_06"
                android:textSize="14dp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_card_group"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_card_group"/>

            <View
                android:id="@+id/view_line"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_02"
                android:layout_marginTop="14dp"
                app:layout_constraintTop_toBottomOf="@id/tv_card_group"
                app:layout_constraintStart_toStartOf="@id/tv_card_group"
                app:layout_constraintEnd_toEndOf="@id/tv_change_verification_card"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_line"
                tools:listitem="@layout/item_require_verifiable_credential_card"
                tools:itemCount="1"/>

            <View
                android:id="@+id/view_bottom_line"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_02"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/recycler_view"
                app:layout_constraintStart_toStartOf="@id/tv_card_group"
                app:layout_constraintEnd_toEndOf="@id/tv_change_verification_card"
                tools:visibility="visible"/>

            <LinearLayout
                android:id="@+id/lay_bottom_select"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_line"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_not_select_verification_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/not_select_verification_credential"
                    android:textSize="14dp"
                    android:textColor="@color/gray_06"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/img_not_select_verification_card"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_exclamation_triangleh"
                    app:tint="@color/secondary_06"/>

            </LinearLayout>

            <View
                android:id="@+id/view_bottom_line_2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_02"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/lay_bottom_select"
                app:layout_constraintStart_toStartOf="@id/tv_card_group"
                app:layout_constraintEnd_toEndOf="@id/tv_change_verification_card"
                tools:visibility="visible"/>

            <LinearLayout
                android:id="@+id/lay_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_line_2"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_non_verification"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/non_verification_credential"
                        android:textSize="14dp"
                        android:textColor="@color/gray_06"
                        android:textStyle="bold"/>

                    <ImageView
                        android:id="@+id/img_non_verification"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_exclamation_triangleh"
                        app:tint="@color/secondary_06"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_show_authorized_verification_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_verification_credential"
                    android:textSize="14dp"
                    android:textColor="@color/primary_06"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>