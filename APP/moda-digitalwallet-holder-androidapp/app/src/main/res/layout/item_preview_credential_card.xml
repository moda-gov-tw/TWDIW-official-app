<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <ImageView
        android:id="@+id/img_radio_btn"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="12dp"

        android:src="@drawable/ic_radio_button_enable"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        app:layout_constraintStart_toEndOf="@id/img_radio_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/img_radio_btn"
        app:layout_constraintBottom_toBottomOf="@id/img_radio_btn"
        tools:text="A123344556、王小明、aaaa@gmail.com..."/>

</androidx.constraintlayout.widget.ConstraintLayout>