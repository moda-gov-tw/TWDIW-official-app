<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="6dp"
    android:paddingBottom="12dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <CheckBox
        android:id="@+id/chk_card_field"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@id/chk_card_field"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/chk_card_field"
        app:layout_constraintBottom_toBottomOf="@id/chk_card_field">

        <TextView
            android:id="@+id/tv_card_field"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16dp"
            android:textColor="@color/gray_08"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="身分證字號"/>

        <TextView
            android:id="@+id/tv_card_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="14dp"
            android:textColor="@color/gray_06"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tv_card_field"
            app:layout_constraintEnd_toEndOf="@id/tv_card_field"
            app:layout_constraintTop_toBottomOf="@id/tv_card_field"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="A123456789"/>

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>