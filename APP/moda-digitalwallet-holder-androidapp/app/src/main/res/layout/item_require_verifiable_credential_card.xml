<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/tv_card_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14dp"
        android:textColor="@color/gray_08"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/img_toggle_expand"
        app:layout_constraintBottom_toBottomOf="@id/img_toggle_expand"
        app:layout_constraintEnd_toStartOf="@id/img_toggle_expand"
        tools:text="身分證明卡"/>

    <ImageView
        android:id="@+id/img_toggle_expand"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:scaleType="centerInside"
        app:srcCompat="@drawable/selector_button_arrow2_up_down"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_preview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14dp"
        android:textColor="@color/gray_06"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingBottom="15dp"
        app:layout_constraintStart_toStartOf="@id/tv_card_name"
        app:layout_constraintEnd_toEndOf="@id/img_toggle_expand"
        app:layout_constraintTop_toBottomOf="@id/img_toggle_expand"
        tools:text="王大ㄧ、A123456789、080.01.05、新北市樹林王大ㄧA1234567、1111"/>

    <TextView
        android:id="@+id/tv_require_issuer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/gray_06"
        android:textSize="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_select_all"
        app:layout_constraintTop_toBottomOf="@id/tv_preview"
        app:layout_constraintVertical_bias="1.0"
        tools:text="中華民國內政部"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/tv_select_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_all"
        android:textSize="14dp"
        android:textColor="@color/primary_06"
        android:layout_marginStart="8dp"
        android:textStyle="bold"
        android:visibility="gone"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_require_issuer"
        app:layout_constraintBottom_toBottomOf="@id/tv_require_issuer"
        tools:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_require_issuer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_require_verifiable_credential_field"
        tools:itemCount="3"
        tools:visibility="visible"/>


</androidx.constraintlayout.widget.ConstraintLayout>