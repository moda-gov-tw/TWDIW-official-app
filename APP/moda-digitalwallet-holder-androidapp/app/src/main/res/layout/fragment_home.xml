<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:id="@+id/view_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view_bottom"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/lay_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="-28dp"
        android:background="@color/gray_01"
        app:layout_constraintBottom_toTopOf="@id/card_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_top" />

    <FrameLayout
        android:id="@+id/card_bottom"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginBottom="-26dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/view_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:background="@drawable/shape_r28_top_radius"
            android:orientation="horizontal"
            android:paddingHorizontal="25dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/tab_wallet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/management_credentials"
                android:textColor="@drawable/selector_tab_text"
                android:textSize="12dp"
                android:textStyle="bold"
                app:drawableTopCompat="@drawable/selector_tab_wallet" />

            <TextView
                android:id="@+id/tab_add_credential"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/add_credentials"
                android:textColor="@drawable/selector_tab_text"
                android:textSize="12dp"
                android:textStyle="bold"
                app:drawableTopCompat="@drawable/selector_tab_add_credential" />

            <TextView
                android:id="@+id/tab_show_credential"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/show_credentials"
                android:textColor="@drawable/selector_tab_text"
                android:textSize="12dp"
                android:textStyle="bold"
                app:drawableTopCompat="@drawable/selector_tab_wallet_barcode" />

            <TextView
                android:id="@+id/tab_scan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/scan"
                android:textColor="@drawable/selector_tab_text"
                android:textSize="12dp"
                android:textStyle="bold"
                app:drawableTopCompat="@drawable/selector_tab_scan" />

            <TextView
                android:id="@+id/tab_setting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/setting"
                android:textColor="@drawable/selector_tab_text"
                android:textSize="12dp"
                android:textStyle="bold"
                app:drawableTopCompat="@drawable/selector_tab_setting" />
        </LinearLayout>

    </FrameLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lay_remind_alerts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/mask_popup"
        android:clickable="true"
        android:elevation="30dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="H,1:1.3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager_remind_alerts"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_remind_alerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/selector_tab_indicator_white"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabPaddingEnd="10dp"
                app:tabPaddingStart="10dp" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>