    "PreviewFeatureVC_Step2Content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "數位憑證皮夾使用獨一無二的密碼鑰匙，彷彿數位保險箱，將各種數位證件、數位憑證妥善保存在手機裡面。未來你可以在多個網路服務間輕鬆把關資料的授權情形，無需每次都要註冊新帳號，或記憶新密碼。一個數位APP無限延展，打造前所未有的安全體驗。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "數位憑證皮夾使用獨一無二的密碼鑰匙，彷彿數位保險箱，將各種數位證件、數位憑證妥善保存在手機裡面。未來你可以在多個網路服務間輕鬆把關資料的授權情形，無需每次都要註冊新帳號，或記憶新密碼。一個數位APP無限延展，打造前所未有的安全體驗。"
          }
        }
      }
