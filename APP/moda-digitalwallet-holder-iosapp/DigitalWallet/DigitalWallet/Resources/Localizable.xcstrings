    "PreviewFeatureVC_Step1Content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "整合多元實體證件，讓你無卡體驗日常服務，不論你在哪，只要拿出手機打開數位憑證皮夾，就能隨時隨地使用，不用再擔心忘記帶證件出門，只需要掃 QR-Code，對方就能快速驗證你的身分，無論是就醫、租車，還是入住飯店，這一切都可以變得前所未有的輕鬆。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "整合多元實體證件，讓你無卡體驗日常服務，不論你在哪，只要拿出手機打開數位憑證皮夾，就能隨時隨地使用，不用再擔心忘記帶證件出門，只需要掃 QR-Code，對方就能快速驗證你的身分，無論是就醫、租車，還是入住飯店，這一切都可以變得前所未有的輕鬆。"
          }
        }
      }
    },
