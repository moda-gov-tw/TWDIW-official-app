# ==============================================================================
# 數位憑證皮夾驗證端管理服務 - 環境變數配置範例檔
# ==============================================================================
# 使用說明：
# 1. 複製此檔案並重新命名為 .env
# 2. 根據實際環境修改各項設定值
# 3. 產生必要的安全金鑰（參考下方說明）
# ==============================================================================

# ==============================================================================
# 資料庫連線設定 (PostgreSQL)
# ==============================================================================
# 資料庫連線 URL
# 格式：jdbc:postgresql://主機:埠號/資料庫名稱
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/twdiw_verifier?currentSchema=vp_manager

# 資料庫使用者名稱
SPRING_DATASOURCE_USERNAME=your_database_username

# 資料庫密碼
SPRING_DATASOURCE_PASSWORD=your_database_password

# -------------------------------------------------------------------
# Spring Profile 設定
# -------------------------------------------------------------------
# 啟用的 Spring Profile（可選：release, test）
# release：正式環境
# test：測試環境
SPRING_PROFILES_ACTIVE=release

# -------------------------------------------------------------------
# 主機名稱設定
# -------------------------------------------------------------------
# 驗證端服務的主機名稱（用於 CORS 與 URL 生成）
# 本機開發：localhost:8080
# 正式環境：your-domain.com
VERIFIER_HOST_NAME=localhost:8080

# ==============================================================================
# JWT 安全性設定
# ==============================================================================
# JHipster JWT Base64 密鑰（必須是 Base64 編碼且至少 256 bits）
# 產生方式：openssl rand -base64 64
# ⚠️ 請勿使用預設值，務必重新產生！
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=

# -------------------------------------------------------------------
# 加密金鑰設定
# -------------------------------------------------------------------
# 屬性加密金鑰（必須是 256-bit / 24 bytes，Base64 編碼）
# 產生方式：openssl rand -base64 24
# ⚠️ 一旦用於加密資料（例如帳號暱稱），初始化後請勿變更。
# ⚠️ 若在未完全解密舊資料前更換秘鑰，將導致原有加密內容無法還原，造成資料無法正確顯示或永久損毀。
ATTRIBUTEENCRYPTOR_KEY=

# RSA 私鑰（Base64 編碼）
# ⚠️ 請參考 README.md [初始化 RSA 金鑰對]產生並設定
FIN_RSAUTIL_PRVKY=

# RSA 公鑰（Base64 編碼）
# ⚠️ 請參考 README.md [初始化 RSA 金鑰對]產生並設定
FIN_RSAUTIL_PKY=

# ==============================================================================
# 應用程式相關設定
# ==============================================================================
# API 版本
API_VERSION=1.0.13

# -------------------------------------------------------------------
# APP 下載設定
# -------------------------------------------------------------------
# Apple Store APP 公開下載連結
# 測試版：https://testflight.apple.com/join/your-testflight-code
# 正式版：https://apps.apple.com/app/your-app-id
APPLE_STORE_APP_URL=https://testflight.apple.com/join/gxr3mQFj

# Google Play APP 公開下載連結
# 測試版：https://play.google.com/apps/testing/your.package.name
# 正式版：https://play.google.com/store/apps/details?id=your.package.name
GOOGLE_PLAY_APP_URL=https://play.google.com/apps/testing/tw.gov.moda.diw

# -------------------------------------------------------------------
# 功能開關設定
# -------------------------------------------------------------------
# OTP 驗證開關（true=開啟驗證, false=關閉驗證）
# 開發環境建議設為 false，正式環境應設為 true
SWITCH_VERIFY_OTP=false

# Jwt 驗簽開關（true=開啟驗簽, false=關閉驗簽）
SWITCH_VERIFY_JWT=true

# 動態 Qr Code 型態，1: 原始 deeplink, 2: Universal/App link
QRCODE_LINK_TYPE=2

# ==============================================================================
# 時間相關設定
# ==============================================================================
# OTP 有效時間（秒，建議值：300 = 5分鐘）
OTP_EXPIRE_TIME=300

# OTP 重發時間（秒，建議值：60 = 1分鐘）
OTP_RE_SEND_TIME=60

# JWT 有效時間（秒，建議值：600 = 10分鐘）
TIME_JWTTIMEOUT=600

# TOTP 時間偏移量（秒，建議值：60）
TIME_TOTPTIMEOUT=60

# TOTP 時間偏移容許值（秒，建議值：30）
TIME_TOTPTIMEOFFSET=30

# ==============================================================================
# 郵件服務設定
# ==============================================================================
# 郵件伺服器主機名稱或 IP 位址
# 範例：smtp.gmail.com, smtp.office365.com, localhost
SPRING_MAIL_HOST=localhost

# 郵件伺服器埠號
# 常見埠號：25 (SMTP), 465 (SMTPS), 587 (SMTP with STARTTLS)
SPRING_MAIL_PORT=25

# 郵件伺服器驗證帳號
SPRING_MAIL_USERNAME=your.smtp.username

# 郵件伺服器驗證密碼
SPRING_MAIL_PASSWORD=your.smtp.password

# -------------------------------------------------------------------
# 內部 API 端點設定
# -------------------------------------------------------------------
# OID4VP 服務內部 URL
# 預設值：http://moda-digitalwallet-docker-verifier-oid4vp-service:8080
OID4VP_INTERNAL_URL=http://moda-digitalwallet-docker-verifier-oid4vp-service:8080

# VP 服務內部 URL
# 預設值：http://moda-digitalwallet-docker-verifier-vp-service:8080
VP_INTERNAL_URL=http://moda-digitalwallet-docker-verifier-vp-service:8080

# ==============================================================================
# 前端服務設定
# ==============================================================================
# 前端服務 URL（依據環境不同而變更）
# 正式環境：https://frontend.wallet.gov.tw
# 測試環境：https://frontend-uat.wallet.gov.tw
DWFRONT_URL=https://frontend.wallet.gov.tw

# 日誌檔案路徑：預設使用專案目錄下的 aplogs 資料夾
# 預設值：aplogs
LOG_PATH=aplogs